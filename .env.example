# Configuration de l'API
# Copier ce fichier en .env et remplir les valeurs avant de démarrer
# Le terminal Git bash et lancer  bash scripts/init_env.sh
# Secrets — OBLIGATOIRES (l'API refuse de démarrer si SECRET_KEY est absente)
# Générer une clé : python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=<générer_avec_la_commande_ci-dessus>
# ADMIN_TOKEN=<générer_avec_la_commande_ci-dessus>

# Base de données PostgreSQL
# Générer un password avev : python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=postgres
# POSTGRES_PASSWORD=<générer_avec_la_commande_ci-dessus>
# DATABASE_URL=postgresql+asyncpg://postgres:<générer_avec_la_commande_ci-dessus>@pgbouncer:5432/sklearn_api
# DATABASE_READ_REPLICA_URL=postgresql+asyncpg://postgres:<générer_avec_la_commande_ci-dessus>@pgbouncer-read:5432/sklearn_api
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# MinIO (stockage modèles)
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD : identifiants du service MinIO dans Docker Compose
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY   : lus par l'API (doivent correspondre aux valeurs ci-dessus)
# Générer un mot de passe en fin de fichier avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=<générer_avec_la_commande_ci-dessus>
MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=<générer_avec_la_commande_ci-dessus>

# Redis Sentinel — haute disponibilité
# Générer un mot de passe en fin de fichier : python -c "import secrets; print(secrets.token_urlsafe(32))"
# REDIS_PASSWORD=<générer_avec_la_commande_ci-dessus>
# REDIS_SENTINEL_HOSTS : vide = connexion directe au master (dev/CI).
# En production Docker Compose, injecté automatiquement par docker-compose.yml.
# Format : "sentinel1:26379,sentinel2:26379,sentinel3:26379"
REDIS_SENTINEL_HOSTS=

# Grafana (monitoring — requis si ENABLE_OTEL=true)
GRAFANA_ADMIN_USER=admin
# Générer un mot de passe : python -c "import secrets; print(secrets.token_urlsafe(32))"
# GRAFANA_ADMIN_PASSWORD=<générer_avec_la_commande_ci-dessus>

# Port de l'API
API_PORT=8000

# CORS — origines autorisées (séparées par virgule)
STREAMLIT_PORT=8501
CORS_ALLOWED_ORIGINS=http://localhost:${STREAMLIT_PORT}

# Durée de vie des tokens Bearer en jours (0 = pas d'expiration)
TOKEN_LIFETIME_DAYS=90

# Prometheus metrics
# Laisser vide = endpoint /metrics public (sûr sur réseau Docker interne).
# Si défini, Prometheus devra aussi utiliser ce token dans monitoring/prometheus.yml
METRICS_TOKEN=

GRAFANA_GRPC_PORT=4317

# OpenTelemetry — envoie traces (Tempo), logs (Loki) et métriques via OTLP vers Grafana LGTM
# Requiert que le service grafana soit démarré (docker-compose up grafana)
ENABLE_OTEL=true
OTEL_SERVICE_NAME=predictml-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana:${GRAFANA_GRPC_PORT}


# Générer automatiquement les secrtes avec la commande 'bash scripts/init_env.sh'
# New terminal > git bash > bash scripts/init_env.sh