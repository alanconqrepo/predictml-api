# Configuration de l'API
# Copier ce fichier en .env et remplir les valeurs avant de démarrer

# Secrets — OBLIGATOIRES en production (générer avec: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=changez-cette-valeur-en-production
ADMIN_TOKEN=changez-cette-valeur-en-production

# Base de données PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changez-cette-valeur-en-production
DATABASE_URL=postgresql+asyncpg://postgres:changez-cette-valeur-en-production@postgres:5432/sklearn_api

# MinIO (stockage modèles)
MINIO_ACCESS_KEY=minio-admin
MINIO_SECRET_KEY=changez-cette-valeur-en-production

# Grafana (monitoring — requis si ENABLE_OTEL=true)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changez-cette-valeur-en-production

# Port de l'API
API_PORT=8000

# CORS — origines autorisées (séparées par virgule)
CORS_ALLOWED_ORIGINS=http://localhost:8501

# Prometheus metrics (laisser vide = endpoint public, sinon token Bearer requis)
METRICS_TOKEN=

# OpenTelemetry (optionnel — mettre ENABLE_OTEL=true pour activer)
ENABLE_OTEL=false
OTEL_SERVICE_NAME=predictml-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana:4317
