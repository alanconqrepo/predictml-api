# Configuration de l'API
# Copier ce fichier en .env et remplir les valeurs avant de démarrer

# Secrets — OBLIGATOIRES (l'API refuse de démarrer si SECRET_KEY est absente)
# Générer une clé : python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<générer_avec_la_commande_ci-dessus>
ADMIN_TOKEN=changez-cette-valeur-en-production

# Base de données PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changez-cette-valeur-en-production
POSTGRES_DB=sklearn_api
# Port exposé sur l'hôte (interne Docker = 5432)
POSTGRES_PORT=5433
# DATABASE_URL utilise pgbouncer (pooler) — valide en Docker Compose.
# Pour un accès local hors Docker, remplacer pgbouncer par localhost et le port exposé.
# Note : mettre à jour ces URLs si POSTGRES_USER, POSTGRES_PASSWORD ou POSTGRES_DB changent.
DATABASE_URL=postgresql+asyncpg://postgres:changez-cette-valeur-en-production@pgbouncer:5432/sklearn_api
DATABASE_READ_REPLICA_URL=postgresql+asyncpg://postgres:changez-cette-valeur-en-production@pgbouncer-read:5432/sklearn_api
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# MinIO (stockage modèles)
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD : identifiants du service MinIO dans Docker Compose
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY   : lus par l'API en dehors de Docker (doivent correspondre aux valeurs ci-dessus)
# Générer un mot de passe : python -c "import secrets; print(secrets.token_urlsafe(32))"
MINIO_ROOT_USER=<choisir_un_utilisateur>
MINIO_ROOT_PASSWORD=<mot_de_passe_fort_32_caracteres_minimum>
MINIO_ACCESS_KEY=<choisir_un_utilisateur>
MINIO_SECRET_KEY=<mot_de_passe_fort_32_caracteres_minimum>
MINIO_BUCKET=models
# Ports exposés sur l'hôte
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Redis Sentinel — haute disponibilité
# Générer un mot de passe : python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=<générer_avec_la_commande_ci-dessus>
# REDIS_SENTINEL_HOSTS : vide = connexion directe au master (dev/CI).
# En production Docker Compose, injecté automatiquement par docker-compose.yml.
# Format : "sentinel1:26379,sentinel2:26379,sentinel3:26379"
REDIS_SENTINEL_HOSTS=
# Durée de mise en cache (secondes)
REDIS_CACHE_TTL=3600

# Prediction stream worker (batch INSERT en DB)
PREDICTION_STREAM_BATCH_SIZE=100
PREDICTION_STREAM_FLUSH_MS=500
PREDICTION_STREAM_MAX_RETRIES=3

# Grafana (monitoring — requis si ENABLE_OTEL=true)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changez-cette-valeur-en-production

# Port de l'API (utilisé par le healthcheck et l'exposition interne)
API_PORT=8000

# Port du dashboard Streamlit exposé sur l'hôte
STREAMLIT_PORT=8501

# CORS — origines autorisées (séparées par virgule)
CORS_ALLOWED_ORIGINS=http://localhost:8501

# Durée de vie des tokens Bearer en jours (0 = pas d'expiration)
TOKEN_LIFETIME_DAYS=90

# Prometheus metrics
# Laisser vide = endpoint /metrics public (sûr sur réseau Docker interne).
# Si défini, Prometheus devra aussi utiliser ce token dans monitoring/prometheus.yml
METRICS_TOKEN=

# OpenTelemetry — envoie traces (Tempo), logs (Loki) et métriques via OTLP vers Grafana LGTM
# Requiert que le service grafana soit démarré (docker-compose up grafana)
ENABLE_OTEL=true
OTEL_SERVICE_NAME=predictml-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana:4317

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://mlflow:5000

# Anthropic — optionnel, requis pour le chatbot IA dans le dashboard Streamlit
ANTHROPIC_API_KEY=
