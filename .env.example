# Configuration de l'API predictml
# 1. Copier ce fichier en .env : cp .env.example .env
# 2. Générer les secrets : New terminal > Git bash > bash scripts/init_env.sh

# =============================================================================
# SECRETS — OBLIGATOIRES (générés automatiquement par scripts/init_env.sh)
# =============================================================================
# SECRET_KEY=
# ADMIN_TOKEN=
# POSTGRES_PASSWORD=
# MINIO_ROOT_PASSWORD=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# REDIS_PASSWORD=
# GRAFANA_ADMIN_PASSWORD=
# MLFLOW_ADMIN_PASSWORD=

# =============================================================================
# Base de données PostgreSQL
# =============================================================================
POSTGRES_DB=sklearn_api
POSTGRES_USER=postgres
POSTGRES_PORT=5433          # Port exposé sur l'hôte (accès local/debug)
POSTGRES_INTERNAL_PORT=5432 # Port interne PostgreSQL (réseau Docker)
PGBOUNCER_PORT=6432         # Port PgBouncer (réseau Docker)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# URLs de connexion construites dynamiquement par docker-compose.
# Utile uniquement pour le dev local sans Docker (remplacer <POSTGRES_PASSWORD>) :
# DATABASE_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@localhost:5433/sklearn_api
# DATABASE_READ_REPLICA_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@localhost:5433/sklearn_api

# =============================================================================
# MinIO (stockage modèles)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_PORT=9010                 # Port API MinIO exposé sur l'hôte (>9004 — évite conflit Jupyter)
MINIO_INTERNAL_PORT=9000        # Port API MinIO interne (réseau Docker)
MINIO_CONSOLE_PORT=9011         # Port console MinIO exposé sur l'hôte
MINIO_CONSOLE_INTERNAL_PORT=9001 # Port console MinIO interne (réseau Docker)
MINIO_BUCKET=models

# =============================================================================
# Redis
# =============================================================================
REDIS_PORT=6379             # Port Redis master/replicas (réseau Docker)
REDIS_SENTINEL_PORT=26379   # Port Redis Sentinel (réseau Docker)
REDIS_CACHE_TTL=3600
# REDIS_SENTINEL_HOSTS : vide = connexion directe au master (dev/CI).
# En production Docker Compose, injecté automatiquement par docker-compose.yml.
# Format : "sentinel1:26379,sentinel2:26379,sentinel3:26379"
REDIS_SENTINEL_HOSTS=

# =============================================================================
# API FastAPI
# =============================================================================
API_PORT=8000       # Port uvicorn interne ET exposé (hôte → Nginx)
NGINX_PORT=80       # Port Nginx exposé sur l'hôte
TOKEN_LIFETIME_DAYS=90
CORS_ALLOWED_ORIGINS=http://localhost:8501
# Email de l'utilisateur admin créé automatiquement au premier démarrage
ADMIN_EMAIL=admin@predictml.local

# Prometheus metrics — obligatoire en production (généré par scripts/init_env.sh)
# Si défini, Prometheus devra aussi utiliser ce token dans monitoring/prometheus.yml
# METRICS_TOKEN=

# Worker Redis Stream — écriture batch des prédictions en DB
PREDICTION_STREAM_BATCH_SIZE=100
PREDICTION_STREAM_FLUSH_MS=500
PREDICTION_STREAM_MAX_RETRIES=3

# =============================================================================
# Streamlit (dashboard admin)
# =============================================================================
STREAMLIT_PORT=8501

# =============================================================================
# MLflow (experiment tracking)
# =============================================================================
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000  # construit via docker-compose depuis MLFLOW_PORT
MLFLOW_ADMIN_USER=admin                 # nom d'utilisateur de l'interface MLflow
# MLFLOW_ADMIN_PASSWORD=               # généré par scripts/init_env.sh
# Credentials client SDK — doivent correspondre à MLFLOW_ADMIN_USER / MLFLOW_ADMIN_PASSWORD
# MLFLOW_TRACKING_USERNAME=            # généré par scripts/init_env.sh (= MLFLOW_ADMIN_USER)
# MLFLOW_TRACKING_PASSWORD=            # généré par scripts/init_env.sh (= MLFLOW_ADMIN_PASSWORD)
# MLFLOW_FLASK_SERVER_SECRET_KEY=      # généré par scripts/init_env.sh (sécurise les sessions Flask MLflow)
MLFLOW_HTTP_REQUEST_TIMEOUT=15
# Credentials MinIO pour les scripts de ré-entraînement (log_model → upload artifact vers MinIO)
# MLFLOW_S3_ENDPOINT_URL=             # généré par scripts/init_env.sh (= http://minio:<MINIO_INTERNAL_PORT>)
# AWS_ACCESS_KEY_ID=                  # généré par scripts/init_env.sh (= MINIO_ROOT_USER)
# AWS_SECRET_ACCESS_KEY=              # généré par scripts/init_env.sh (= MINIO_ROOT_PASSWORD)
# =============================================================================
# Grafana LGTM (monitoring — requis si ENABLE_OTEL=true)
# =============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_PORT=3000
GRAFANA_GRPC_PORT=4317
GRAFANA_OTLP_HTTP_PORT=4318

ENABLE_OTEL=true
OTEL_SERVICE_NAME=predictml-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana:4317

# =============================================================================
# Alertes e-mail (optionnel — décommentez et configurez pour activer)
# =============================================================================
# ENABLE_EMAIL_ALERTS=false
# WEEKLY_REPORT_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_STARTTLS=true
# SMTP_USER=alerts@company.com
# SMTP_PASSWORD=secret
# SMTP_FROM=alerts@predictml.io
# ALERT_EMAIL_TO=admin@company.com
# STREAMLIT_URL=http://localhost:8501
# WEEKLY_REPORT_DAY=monday
# WEEKLY_REPORT_HOUR=8
# PERFORMANCE_DRIFT_ALERT_THRESHOLD=0.10
# ERROR_RATE_ALERT_THRESHOLD=0.10

# =============================================================================
# Intégrations externes (optionnelles)
# =============================================================================
ANTHROPIC_API_KEY=
