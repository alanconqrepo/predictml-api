# Configuration de l'API
API_TOKEN=your-secret-token-here

# Port de l'API
API_PORT=8000

# Dossier contenant les modèles
MODELS_DIR=/app/Models

# OpenTelemetry (optionnel — mettre ENABLE_OTEL=true pour activer)
# Nécessite le service grafana dans docker-compose (grafana/otel-lgtm)
# Interface Grafana disponible sur http://localhost:3000 (admin/admin)
ENABLE_OTEL=false
OTEL_SERVICE_NAME=predictml-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://grafana:4317
