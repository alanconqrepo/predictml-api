{
  "uid": "predictml-model-performance",
  "title": "PredictML — Model Performance",
  "description": "Accuracy par modèle, drift status, événements de ré-entraînement et logs d'erreur",
  "tags": ["predictml", "models", "prometheus", "loki"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "links": [
    {
      "title": "API Overview",
      "url": "/d/predictml-api-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "label": "Intervalle",
        "current": { "value": "5m", "text": "5m" },
        "options": [
          { "value": "1m",  "text": "1m" },
          { "value": "5m",  "text": "5m" },
          { "value": "10m", "text": "10m" },
          { "value": "30m", "text": "30m" }
        ],
        "hide": 0,
        "query": "1m,5m,10m,30m"
      },
      {
        "name": "model_name",
        "type": "query",
        "label": "Modèle",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(predictml_predictions_total, model_name)",
        "current": { "value": "$__all", "text": "All" },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Volume /predict (req/s)",
      "description": "Taux de prédictions par seconde sur la fenêtre sélectionnée",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\"}[$interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Erreurs /predict (%)",
      "description": "Part des réponses 4xx/5xx sur l'endpoint /predict",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"[45]..\"}[$interval])) / clamp_min(sum(rate(http_requests_total{handler=~\"/predict.*\"}[$interval])), 1)",
          "legendFormat": "% erreurs",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latence P95 /predict",
      "description": "95e percentile de la durée de l'endpoint /predict",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P95 ms",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Volume de prédictions dans le temps",
      "description": "Taux de requêtes /predict par seconde — codes 2xx (succès) vs codes d'erreur",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"2..\"}[$interval]))",
          "legendFormat": "Succès (2xx)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"4..\"}[$interval]))",
          "legendFormat": "Erreurs client (4xx)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"5..\"}[$interval]))",
          "legendFormat": "Erreurs serveur (5xx)",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Succès (2xx)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Erreurs client (4xx)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Erreurs serveur (5xx)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latence /predict — P50 / P95 / P99",
      "description": "Percentiles de durée de l'inférence ML (latence endpoint /predict)",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Taux d'erreurs /models (gestion modèles)",
      "description": "Erreurs sur les routes de gestion de modèles (upload, retrain, schedule…)",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/models.*\", status_code=~\"[45]..\"}[$interval])) by (handler, status_code)",
          "legendFormat": "{{handler}} ({{status_code}})",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Événements de ré-entraînement (OTEL requis)",
      "description": "Logs structurés liés aux retrains — nécessite ENABLE_OTEL=true pour être alimenté",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"predictml-api\"} |= \"retrain\" | json | model_name =~ \"$model_name\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Alertes drift / supervision (OTEL requis)",
      "description": "Logs liés à la détection de drift et aux alertes de performance — nécessite ENABLE_OTEL=true",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"predictml-api\"} |= \"drift\" | json | model_name =~ \"$model_name\"",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "{service_name=\"predictml-api\"} |= \"alert\" | json | model_name =~ \"$model_name\"",
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Logs d'erreur récents (OTEL requis)",
      "description": "Toutes les lignes de log de niveau ERROR ou WARNING — nécessite ENABLE_OTEL=true",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"predictml-api\"} | json | level =~ \"(?i)(error|warning|warn|critical)\" | model_name =~ \"$model_name\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 10,
      "type": "text",
      "title": "Note — panels Loki",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 38 },
      "options": {
        "mode": "markdown",
        "content": "**Les panels de logs (ci-dessus) et métriques ML (ci-dessous) nécessitent `ENABLE_OTEL=true` dans le `.env`** — activé par défaut depuis la v2.1.  \nPour explorer les traces, utilisez le datasource **Tempo** dans Grafana → Explore.  \nVoir [documentation/GRAFANA_OTEL.md](https://github.com/alanconqrepo/predictml-api/blob/main/documentation/GRAFANA_OTEL.md) pour les détails."
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Prédictions par modèle (predictml_predictions_total)",
      "description": "Taux de prédictions par seconde, filtré par modèle et statut. Source : compteur Prometheus ML custom.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(predictml_predictions_total{model_name=~\"$model_name\", status=\"success\"}[$interval])) by (model_name, version)",
          "legendFormat": "{{model_name}} {{version}} ✓",
          "refId": "A"
        },
        {
          "expr": "sum(rate(predictml_predictions_total{model_name=~\"$model_name\", status=\"error\"}[$interval])) by (model_name, version)",
          "legendFormat": "{{model_name}} {{version}} ✗",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Latence d'inférence ML P95 par modèle",
      "description": "95e percentile de la durée d'inférence ML (endpoint /predict complet) par modèle. Source : histogram Prometheus ML custom.",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(predictml_inference_duration_seconds_bucket{model_name=~\"$model_name\"}[$interval])) by (le, model_name)) * 1000",
          "legendFormat": "{{model_name}} P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(predictml_inference_duration_seconds_bucket{model_name=~\"$model_name\"}[$interval])) by (le, model_name)) * 1000",
          "legendFormat": "{{model_name}} P95",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Retrains (total période)",
      "description": "Nombre de ré-entraînements déclenchés (manuels + planifiés) sur la période sélectionnée.",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(predictml_retrain_total{model_name=~\"$model_name\", status=\"success\"}[$interval]))",
          "legendFormat": "succès",
          "refId": "A"
        },
        {
          "expr": "sum(increase(predictml_retrain_total{model_name=~\"$model_name\", status=\"failure\"}[$interval]))",
          "legendFormat": "échecs",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "vertical",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "échecs" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Drifts détectés (période)",
      "description": "Événements de drift (feature, performance, output, error_rate) détectés par le scheduler de supervision.",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(predictml_drift_detected_total{model_name=~\"$model_name\", severity=\"critical\"}[$interval]))",
          "legendFormat": "critical",
          "refId": "A"
        },
        {
          "expr": "sum(increase(predictml_drift_detected_total{model_name=~\"$model_name\", severity=\"warning\"}[$interval]))",
          "legendFormat": "warning",
          "refId": "B"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "orientation": "vertical",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Drift détecté par type (predictml_drift_detected_total)",
      "description": "Événements de drift cumulés sur la période, par type et sévérité. Source : counter Prometheus ML custom.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 57 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(predictml_drift_detected_total{model_name=~\"$model_name\"}[$interval])) by (model_name, drift_type, severity)",
          "legendFormat": "{{model_name}} — {{drift_type}} ({{severity}})",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      }
    }
  ]
}
