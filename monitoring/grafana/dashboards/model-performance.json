{
  "uid": "predictml-model-performance",
  "title": "PredictML — Model Performance",
  "description": "Accuracy par modèle, drift status, événements de ré-entraînement et logs d'erreur",
  "tags": ["predictml", "models", "prometheus", "loki"],
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "fiscalYearStartMonth": 0,
  "links": [
    {
      "title": "API Overview",
      "url": "/d/predictml-api-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "label": "Intervalle",
        "current": { "value": "5m", "text": "5m" },
        "options": [
          { "value": "1m",  "text": "1m" },
          { "value": "5m",  "text": "5m" },
          { "value": "10m", "text": "10m" },
          { "value": "30m", "text": "30m" }
        ],
        "hide": 0,
        "query": "1m,5m,10m,30m"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Volume /predict (req/s)",
      "description": "Taux de prédictions par seconde sur la fenêtre sélectionnée",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\"}[$interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 3,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Erreurs /predict (%)",
      "description": "Part des réponses 4xx/5xx sur l'endpoint /predict",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"[45]..\"}[$interval])) / clamp_min(sum(rate(http_requests_total{handler=~\"/predict.*\"}[$interval])), 1)",
          "legendFormat": "% erreurs",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latence P95 /predict",
      "description": "95e percentile de la durée de l'endpoint /predict",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P95 ms",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Volume de prédictions dans le temps",
      "description": "Taux de requêtes /predict par seconde — codes 2xx (succès) vs codes d'erreur",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"2..\"}[$interval]))",
          "legendFormat": "Succès (2xx)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"4..\"}[$interval]))",
          "legendFormat": "Erreurs client (4xx)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/predict.*\", status_code=~\"5..\"}[$interval]))",
          "legendFormat": "Erreurs serveur (5xx)",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Succès (2xx)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Erreurs client (4xx)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Erreurs serveur (5xx)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latence /predict — P50 / P95 / P99",
      "description": "Percentiles de durée de l'inférence ML (latence endpoint /predict)",
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler=~\"/predict.*\"}[$interval])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 8, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Taux d'erreurs /models (gestion modèles)",
      "description": "Erreurs sur les routes de gestion de modèles (upload, retrain, schedule…)",
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"/models.*\", status_code=~\"[45]..\"}[$interval])) by (handler, status_code)",
          "legendFormat": "{{handler}} ({{status_code}})",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Événements de ré-entraînement (OTEL requis)",
      "description": "Logs structurés liés aux retrains — nécessite ENABLE_OTEL=true pour être alimenté",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"predictml-api\"} |= \"retrain\" | json",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Alertes drift / supervision (OTEL requis)",
      "description": "Logs liés à la détection de drift et aux alertes de performance — nécessite ENABLE_OTEL=true",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"predictml-api\"} |= \"drift\" | json",
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "{service_name=\"predictml-api\"} |= \"alert\" | json",
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Logs d'erreur récents (OTEL requis)",
      "description": "Toutes les lignes de log de niveau ERROR ou WARNING — nécessite ENABLE_OTEL=true",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service_name=\"predictml-api\"} | json | level =~ \"(?i)(error|warning|warn|critical)\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 10,
      "type": "text",
      "title": "Note — panels Loki",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 38 },
      "options": {
        "mode": "markdown",
        "content": "**Les panels de logs ci-dessus nécessitent `ENABLE_OTEL=true` dans le `.env`.**  \nSans OTEL, les logs ne sont pas envoyés à Loki et les panels restent vides.  \nPour explorer les traces, utilisez le datasource **Tempo** dans le menu Explore de Grafana.  \nVoir [documentation/GRAFANA_OTEL.md](https://github.com/alanconqrepo/predictml-api/blob/main/documentation/GRAFANA_OTEL.md) pour les détails."
      }
    }
  ]
}
